    <inertial>
      <mass value="0.5"/>
      <inertia ixx="0.002" ixy="0" ixz="0" iyy="0.002" iyz="0" izz="0.002"/>
    </inertial>
  </link>
  <joint name="joint_rueda_td" type="continuous">
    <parent link="chasis"/>
    <child link="rueda_td"/>
    <origin xyz="-0.15 -0.175 -0.01"/>
    <axis xyz="0 1 0"/>
  </joint>

</robot>
