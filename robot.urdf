<?xml version="1.0"?>
<robot name="rover_basico">

  <link name="chasis">
    <visual>
      <geometry><box size="0.4 0.3 0.08"/></geometry>
      <material name="azul"><color rgba="0 0.2 0.8 1"/></material>
    </visual>
    <collision>
      <geometry><box size="0.4 0.3 0.08"/></geometry>
    </collision>
    <inertial>
      <mass value="3.0"/>
      <inertia ixx="0.1" ixy="0" ixz="0" iyy="0.1" iyz="0" izz="0.1"/>
    </inertial>
  </link>

  <!-- RUEDA DELANTERA IZQUIERDA (joint 0) -->
  <link name="rueda_di">
    <visual>
      <origin rpy="1.5708 0 0"/>
      <geometry><cylinder radius="0.07" length="0.05"/></geometry>
      <material name="negro"><color rgba="0.1 0.1 0.1 1"/></material>
    </visual>
    <collision>
      <origin rpy="1.5708 0 0"/>
      <geometry><cylinder radius="0.07" length="0.05"/></geometry>
    </collision>
    <inertial>
      <mass value="0.5"/>
      <inertia ixx="0.002" ixy="0" ixz="0" iyy="0.002" iyz="0" izz="0.002"/>
    </inertial>
  </link>
  <joint name="joint_rueda_di" type="continuous">
    <parent link="chasis"/>
    <child link="rueda_di"/>
    <origin xyz="0.15 0.175 -0.01"/>
    <axis xyz="0 1 0"/>
  </joint>

  <!-- RUEDA DELANTERA DERECHA (joint 1) -->
  <link name="rueda_dd">
    <visual>
      <origin rpy="1.5708 0 0"/>
      <geometry><cylinder radius="0.07" length="0.05"/></geometry>
      <material name="negro"><color rgba="0.1 0.1 0.1 1"/></material>
    </visual>
    <collision>
      <origin rpy="1.5708 0 0"/>
      <geometry><cylinder radius="0.07" length="0.05"/></geometry>
    </collision>
    <inertial>
      <mass value="0.5"/>
      <inertia ixx="0.002" ixy="0" ixz="0" iyy="0.002" iyz="0" izz="0.002"/>
    </inertial>
  </link>
  <joint name="joint_rueda_dd" type="continuous">
    <parent link="chasis"/>
    <child link="rueda_dd"/>
    <origin xyz="0.15 -0.175 -0.01"/>
    <axis xyz="0 1 0"/>
  </joint>

  <!-- RUEDA TRASERA IZQUIERDA (joint 2) -->
  <link name="rueda_ti">
    <visual>
      <origin rpy="1.5708 0 0"/>
      <geometry><cylinder radius="0.07" length="0.05"/></geometry>
      <material name="negro"><color rgba="0.1 0.1 0.1 1"/></material>
    </visual>
    <collision>
      <origin rpy="1.5708 0 0"/>
      <geometry><cylinder radius="0.07" length="0.05"/></geometry>
    </collision>
    <inertial>
      <mass value="0.5"/>
      <inertia ixx="0.002" ixy="0" ixz="0" iyy="0.002" iyz="0" izz="0.002"/>
    </inertial>
  </link>
  <joint name="joint_rueda_ti" type="continuous">
    <parent link="chasis"/>
    <child link="rueda_ti"/>
    <origin xyz="-0.15 0.175 -0.01"/>
    <axis xyz="0 1 0"/>
  </joint>

  <!-- RUEDA TRASERA DERECHA (joint 3) -->
  <link name="rueda_td">
    <visual>
      <origin rpy="1.5708 0 0"/>
      <geometry><cylinder radius="0.07" length="0.05"/></geometry>
      <material name="negro"><color rgba="0.1 0.1 0.1 1"/></material>
    </visual>
    <collision>
      <origin rpy="1.5708 0 0"/>
      <geometry><cylinder radius="0.07" length="0.05"/></geometry>
